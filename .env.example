# ─────────────────────────────────────────
# BASE DE DATOS
# ─────────────────────────────────────────
POSTGRES_USER=electoral_user
POSTGRES_PASSWORD=electoral_pass
POSTGRES_DB=electoral_db

# ─────────────────────────────────────────
# BACKEND
# ─────────────────────────────────────────
# URL completa usada por SQLAlchemy
# En Docker: apunta al servicio "db" del compose
# En Railway: Railway inyecta esta variable automáticamente
DATABASE_URL=postgresql://electoral_user:electoral_pass@localhost:5432/electoral_db

# Minutos que tiene un votante para completar su voto
# después de registrar su cédula (bloqueo por inactividad)
TIEMPO_LIMITE_VOTO_MINUTOS=5

# "development" | "production"
ENVIRONMENT=development

# ─────────────────────────────────────────
# FRONTEND (React)
# ─────────────────────────────────────────
# URL base de la API que consume React
# En local: http://localhost:8000
# En Railway: la URL pública del backend desplegado
REACT_APP_API_URL=http://localhost:8000
